# OpenClaw Cron Dashboard — environment configuration
# Copy to `.env.local` and fill in the values you want.

# ─────────────────────────────────────────────────────────────────────────────
# Discord failure alerts
# ─────────────────────────────────────────────────────────────────────────────
# Set DISCORD_WEBHOOK_URL to receive a Discord ping whenever the dashboard's
# alert endpoint is called (typically when a job has consecutive failures).
#
# Create the webhook in Discord: Server Settings → Integrations → Webhooks →
# New Webhook → "OpenClaw Cron" → copy URL.
#
# Leave blank to disable Discord alerting.
DISCORD_WEBHOOK_URL=

# Optional: ping a specific user on failure (uses Discord's @mention syntax,
# e.g. "<@1194064134879314003>" — leave blank to skip the mention).
DISCORD_MENTION_USER_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Alert thresholds
# ─────────────────────────────────────────────────────────────────────────────
# How many consecutive failures before the dashboard will fire an alert.
# Default: 2 (one transient blip won't ping you).
ALERT_CONSECUTIVE_FAILURES=2

# How many hours a job can go without a successful run before it counts as
# "stale" and triggers an alert. Default: 24.
ALERT_STALE_HOURS=24

# How often the dashboard may re-fire an alert for the SAME job (minutes).
# Prevents alert spam if a job keeps failing. Default: 60.
ALERT_COOLDOWN_MINUTES=60
